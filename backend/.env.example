# Local dev: path to your Google Service Account JSON key file
# Cloud Run: store the *contents* of the JSON in Secret Manager as
#            GOOGLE_SERVICE_ACCOUNT_JSON and mount it as an env var.
# This account needs: Cloud Vision API User + Editor access to the Google Sheet
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# Google Sheets target spreadsheet ID (from the sheet URL)
GOOGLE_SHEET_ID=your_google_sheet_id

# Sheet tab name
GOOGLE_SHEET_TAB=your_google_sheet_tab_name

# GCP project ID (found in Google Cloud Console)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# Allowed origin for CORS (front-end dev server)
FRONTEND_ORIGIN=http://localhost:3000

# WRMD taxa search — used to validate species names against the WRMD common-names list
# Get your key from wrmd.org → account settings → API tokens
WRMD_API_KEY=your_wrmd_api_key
